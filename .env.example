# ============================================================
# FILE MẪU — copy thành .env / .env.local rồi điền giá trị thật.
# KHÔNG điền bí mật vào file này (file này được commit lên git).
# ============================================================

# ===== Database (PostgreSQL) — đặt trong .env =====
# Đổi MAT_KHAU thành mật khẩu user postgres của bạn.
DATABASE_URL="postgresql://postgres:MAT_KHAU@localhost:5432/kolhub?schema=public"

# ===== Gmail API (OAuth2) — đặt trong .env.local =====
# Lấy tại: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL callback — phải TRÙNG với "Authorized redirect URI" trên Google Cloud.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback
# Khi deploy online: https://<ten-mien>/api/gmail/callback

# URL gốc của app
APP_URL=http://localhost:3000
